# Copy this file to .env.local and fill in the values.
# Bun auto-loads .env — no dotenv needed.
#
# These credentials are used by `bun run preprocess` to upload GLB assets to R2.
# Preprocess will skip uploads if credentials are missing (URLs still rewritten).

# Cloudflare account ID (find at: https://dash.cloudflare.com → right sidebar)
CLOUDFLARE_ACCOUNT_ID=

# R2 bucket name (default: 3d-assets)
R2_BUCKET=3d-assets

# R2 API token — create at:
#   https://dash.cloudflare.com/profile/api-tokens
#   → Create Token → R2 Token → Object Read & Write
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Optional: override the base URL for asset downloads (default: https://assets.fried.gg)
# ASSETS_BASE_URL=https://assets.fried.gg

# Gemini API key — used by `bun run tag` to generate vision-based style tags
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
