{
  "name": "3d-assets-search",
  "version": "1.0.0",
  "description": "MCP server — search Quaternius low-poly 3D assets by name, category, or animation clip",
  "type": "module",
  "scripts": {
    "fetch": "bun scripts/fetch-polypizza.ts",
    "preprocess": "bun scripts/preprocess.ts",
    "pipeline": "bun run fetch && bun run preprocess",
    "prestart": "bun run preprocess",
    "start": "bun src/mcp-server.ts",
    "predev": "bun run preprocess",
    "dev": "wrangler dev",
    "predeploy": "bun run preprocess",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types src/worker-configuration.d.ts",
    "test": "vitest run",
    "format": "oxfmt --write .",
    "lint": "oxlint .",
    "check": "oxfmt --write . && oxlint ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.26.0",
    "@types/natural": "^6.0.1",
    "agents": "^0.5.0",
    "natural": "^8.1.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "@types/bun": "latest",
    "lefthook": "^1.11.13",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "typescript": "^5",
    "vitest": "^4.0.18",
    "wrangler": "^4.0.0"
  }
}
